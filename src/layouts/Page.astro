---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="p-4 prose">
		<slot />
	</body>
</html>
<style is:global>
	html {
		font-family: monospace;
	}

	a {
		text-decoration: underline;
	}

	h1 {
		font-size: 2rem;
	}

	img {
		filter: grayscale(100%);
	}
</style>
